# Copy to `.env` at repo root. Never commit real `.env`.
# Docker Compose loads this for `server` (and build args for `client` at `docker compose build client`).
# Required to start: JWT_SECRET, DATABASE_PASSWORD — see server/src/config/environment.validation.ts.
# NODE_ENV=production: SESSION_SECRET and COOKIE_SECRET must not stay on scaffold placeholders.

# --- Public URLs (browser / OAuth / CORS) ---
SERVER_URL=http://localhost:3002
# OAuth / CORS. Docker+nginx client: http://localhost:3000. Vite-only dev: http://localhost:5173
CLIENT_URL=http://localhost:3000
# Quick Tunnel demo: set SERVER_URL and CLIENT_URL to the same https://*.trycloudflare.com (no trailing slash), then rebuild client.
# Optional overrides (defaults: SERVER_URL / CLIENT_URL)
# API_PUBLIC_BASE_URL=
# CORS_ORIGIN=
# SERVER_PUBLIC_URL=

# Baked into client at `docker compose build client` (see vite.config / ApiConfig).
VITE_API_BASE_URL=USE_ORIGIN_API_PREFIX
# VITE_APP_NAME=
# Dev-only simulated card checkout in PaymentDialog is shown when MODE=development, or set true to force on prod builds.
# VITE_ENABLE_MANUAL_CREDIT_PAYMENT=true

# --- Auth: Google OAuth (optional if unused) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Auth: JWT / session ---
JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d
SESSION_SECRET=everytriv-oauth-session-secret
COOKIE_SECRET=everytriv-cookie-signing-secret-change-in-production
# false = local http; use true behind https (e.g. public tunnel) if cookies misbehave
COOKIE_SECURE=false
# Public Quick Tunnel demo: sync-demo-redirect.ps1 / pnpm run start:demo set COOKIE_SECURE=true when CLIENT_URL is https://.

# --- Database ---
# In Docker: host `postgres` / `redis` match compose service names. Local `pnpm`/IDE: loadEnv.ts maps those to 127.0.0.1.
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USERNAME=everytriv_user
DATABASE_PASSWORD=your-database-password-here
DATABASE_NAME=everytriv
DATABASE_SCHEMA=public
DATABASE_SSL=false
DATABASE_LOGGING=false

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=change-redis-password
# REDIS_KEY_PREFIX=

# --- Runtime ---
# `development` = local. `production` or `prod` = production-like (server enforces non-placeholder SESSION_SECRET / COOKIE_SECRET).
NODE_ENV=development
PORT=3002
DOMAIN=localhost
LOG_DIR=logs
ENABLE_DEBUG_LOGGING=false

# --- Feature flags (optional; safe defaults if omitted) ---
# ENABLE_RATE_LIMIT=
# DISABLE_AI_FALLBACK=
# DISABLE_RATE_LIMIT_FOR_LOCALHOST=

# --- AI trivia (Groq) ---
GROQ_API_KEY=

# --- PayPal (optional) ---
# PAYPAL_ENVIRONMENT=sandbox
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_MERCHANT_ID=
# PAYPAL_WEBHOOK_ID=

# --- Other integrations (optional) ---
# LANGUAGE_TOOL_API_KEY=
# MULTIPLAYER_WS_URL=
