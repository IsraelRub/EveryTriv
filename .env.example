# Copy to `.env` at repo root. Never commit real `.env`.
# Required for a healthy boot: JWT_SECRET, DATABASE_PASSWORD (see environment.validation.ts).
# In NODE_ENV=production: also replace SESSION_SECRET and COOKIE_SECRET placeholders.

# --- Public URLs (browser / OAuth / CORS) ---
SERVER_URL=http://localhost:3002
CLIENT_URL=http://localhost:3000
# Optional overrides (defaults: SERVER_URL / CLIENT_URL)
# API_PUBLIC_BASE_URL=
# CORS_ORIGIN=
# SERVER_PUBLIC_URL=

# Baked into client at `docker compose build client` (see vite.config / ApiConfig).
VITE_API_BASE_URL=USE_ORIGIN_API_PREFIX
# VITE_APP_NAME=

# --- Auth: Google OAuth (optional if unused) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Auth: JWT / session ---
JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d
SESSION_SECRET=everytriv-oauth-session-secret
COOKIE_SECRET=everytriv-cookie-signing-secret-change-in-production
COOKIE_SECURE=false

# --- Database (Docker service names match defaults below) ---
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USERNAME=everytriv_user
DATABASE_PASSWORD=your-database-password-here
DATABASE_NAME=everytriv
DATABASE_SCHEMA=public
DATABASE_SSL=false
DATABASE_LOGGING=false

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=change-redis-password
# REDIS_KEY_PREFIX=

# --- Runtime ---
NODE_ENV=development
PORT=3002
API_VERSION=v1
DOMAIN=localhost
LOG_DIR=logs
ENABLE_DEBUG_LOGGING=false

# --- Feature flags (optional; safe defaults if omitted) ---
# ENABLE_RATE_LIMIT=
# DISABLE_AI_FALLBACK=
# DISABLE_RATE_LIMIT_FOR_LOCALHOST=

# --- AI trivia (Groq) ---
GROQ_API_KEY=

# --- PayPal (optional) ---
# PAYPAL_ENVIRONMENT=sandbox
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_MERCHANT_ID=
# PAYPAL_WEBHOOK_ID=

# --- Other integrations (optional) ---
# LANGUAGE_TOOL_API_KEY=
# MULTIPLAYER_WS_URL=
