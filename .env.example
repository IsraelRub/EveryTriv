# Copy to `.env` at repo root. Never commit a real `.env`.
# Local-only values (secrets, overrides) belong in `.env` — do not add `*.local` env files to this repo.
#
# Layout:
# - `.env` — secrets and shared config only (JWT, DB/Redis passwords, API keys, `VITE_*`, `DOMAIN`, `COOKIE_SECURE`, …).
#   Do not put here: `SERVER_URL`, `CLIENT_URL`, `PORT`, `NODE_ENV`, `DATABASE_HOST`, `REDIS_HOST` — those belong in `.env.dev` or `.env.prod`.
# - `.env.dev` — local dev without Docker (Vite :5173, API :3001, DB/Redis on localhost).
# - `.env.prod` — Docker / production-like (client :3000, API :3002 on host, service hostnames postgres/redis).
# Loading: `server/src/loadEnv.ts` merges `.env` then dev or prod. In a Linux container, `.env.prod` is merged with override=false so Compose stays authoritative.
# Host profile: default from `NODE_ENV` (`prod` → `.env.prod` overlay; anything else → `.env.dev`), or set `DOTENV_PROFILE=dev|prod`.
# Vite: `pnpm run start` uses `--mode dev`; build/preview use `--mode prod` (loads root `.env.dev` / `.env.prod`).
#
# Docker Compose may still inject vars for client build; see `docker-compose.yaml`.
# Required to start: JWT_SECRET, DATABASE_PASSWORD — see `server/src/config/environment.validation.ts`.
# NODE_ENV=prod: SESSION_SECRET and COOKIE_SECRET must not stay on placeholders.

# --- Public URLs (defaults live in `.env.dev` / `.env.prod`; override here if needed) ---
# SERVER_URL=
# CLIENT_URL=

# Quick Tunnel demo: set SERVER_URL and CLIENT_URL to the same https://*.trycloudflare.com (no trailing slash), then rebuild client.
# Optional overrides (defaults: SERVER_URL / CLIENT_URL)
# API_PUBLIC_BASE_URL=
# CORS_ORIGIN=
# SERVER_PUBLIC_URL=

# Baked into client (see vite.config / ApiConfig). Shared across profiles.
VITE_API_BASE_URL=USE_ORIGIN_API_PREFIX
# VITE_APP_NAME=
# Dev-only simulated card checkout in PaymentDialog — see `import.meta.env.DEV` / `VITE_ENABLE_MANUAL_CREDIT_PAYMENT`
# VITE_ENABLE_MANUAL_CREDIT_PAYMENT=true

# --- Auth: Google OAuth (optional if unused) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Auth: JWT / session ---
JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d
SESSION_SECRET=everytriv-oauth-session-secret
COOKIE_SECRET=everytriv-cookie-signing-secret-change-in-production
# false = local http; use true behind https (e.g. public tunnel) if cookies misbehave
COOKIE_SECURE=false
# Public Quick Tunnel demo: sync-demo-redirect.ps1 / pnpm run start:demo set COOKIE_SECURE=true when CLIENT_URL is https://.

# --- Database (HOST lives in `.env.dev` / `.env.prod`) ---
DATABASE_PORT=5432
DATABASE_USERNAME=everytriv_user
DATABASE_PASSWORD=your-database-password-here
DATABASE_NAME=everytriv
DATABASE_SCHEMA=public
DATABASE_SSL=false
DATABASE_LOGGING=false

# --- Redis (HOST/PORT come from `.env.dev` / `.env.prod`; password must match the running instance) ---
# Local Redis **without** `requirepass`: leave empty → `REDIS_PASSWORD=` or omit the line (see `AppConfig.redis`).
# Tracked `.env.dev` uses port **6380** + password `EveryTrivLocalRedis6380!` for Windows Redis alongside Docker on 6379 — see `docs/LOCAL_DEV_NO_DOCKER.md`.
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=change-redis-password
# REDIS_KEY_PREFIX=

# --- Runtime (NODE_ENV/PORT in profile files; override here if needed) ---
# PORT=
DOMAIN=localhost
LOG_DIR=logs
# Truncate server.log on process start (set true for a clean file each run).
LOG_CLEAR_ON_START=false
# Max active server.log size before rename rotation; 0 = unlimited (no size rotation).
LOG_MAX_FILE_BYTES=10485760
# Kept rotated files: server.log.1 … server.log.N (oldest dropped).
LOG_MAX_ARCHIVED_FILES=5
ENABLE_DEBUG_LOGGING=false

# --- Feature flags (optional; safe defaults if omitted) ---
# Bulk admin clears (game history, trivia, user stats, test-user cleanup): off in NODE_ENV=prod unless explicitly enabled.
# Server: set true only when you need these endpoints in production (e.g. scripted ops). The production admin UI does not expose bulk-clear actions.
# ENABLE_ADMIN_DATA_MAINTENANCE=
# ENABLE_RATE_LIMIT=
# DISABLE_AI_FALLBACK=
# DISABLE_RATE_LIMIT_FOR_LOCALHOST=

# --- AI trivia (Groq) ---
GROQ_API_KEY=

# --- PayPal (optional; empty clientId until filled — server may return REQUIRES_ACTION) ---
PAYPAL_ENVIRONMENT=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MERCHANT_ID=
# Webhook signature verify; falls back to PAYPAL_MERCHANT_ID if unset
PAYPAL_WEBHOOK_ID=

# --- Other integrations (optional) ---
LANGUAGE_TOOL_API_KEY=
MULTIPLAYER_WS_URL=
