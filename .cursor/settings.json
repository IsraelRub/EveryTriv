{
  // Cursor IDE settings for EveryTriv monorepo

  // Format on save (IDE behavior, not in Prettier config)
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "explicit"
  },

  // Point IDE to shared config files (monorepo setup)
  "prettier.configPath": "./tools/.prettierrc",
  "prettier.ignorePath": "./tools/.prettierignore",
  "prettier.requireConfig": true,
  "prettier.useEditorConfig": false,

  // ESLint multi-workspace setup (monorepo)
  "eslint.enable": true,
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],
  "eslint.workingDirectories": [
    { "pattern": "./client" },
    { "pattern": "./server" },
    { "pattern": "./shared" }
  ],

  // Language-specific formatters (IDE needs to know which formatter to use)
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit",
      "source.organizeImports": "explicit"
    }
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit",
      "source.organizeImports": "explicit"
    }
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.wordWrap": "on",
    "editor.quickSuggestions": {
      "comments": "off",
      "strings": "off",
      "other": "off"
    }
  },

  // TypeScript IDE preferences (separate from tsconfig.json compiler options)
  // These control IDE behavior, not compilation
  "typescript.preferences.importModuleSpecifier": "non-relative",
  "typescript.updateImportsOnFileMove.enabled": "always",
  "typescript.preferences.quoteStyle": "single",
  "typescript.preferences.includePackageJsonAutoImports": "on",
  "javascript.preferences.includePackageJsonAutoImports": "on",

  // Editor visual settings (not in Prettier - these are IDE display settings)
  "editor.rulers": [120],
  "editor.wordWrap": "off",
  "editor.semanticHighlighting.enabled": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": "active",

  // File associations
  "files.associations": {
    "*.mdc": "markdown"
  },

  // Exclude patterns (IMPORTANT - improves IDE and AI performance)
  "files.exclude": {
    "**/.git": true,
    "**/.DS_Store": true,
    "**/node_modules": true,
    "**/dist": true,
    "**/build": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/build": true,
    "**/pnpm-lock.yaml": true,
    "**/package-lock.json": true
  },
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/build/**": true
  },

  // Performance optimizations
  "files.maxMemoryForLargeFilesMB": 4096,

// AI Assistant settings
  "ai": {
    "autoComplete": true,
    "suggestions": true,
    "explainCode": true,
    "preferredLanguage": "en",
    "context": {
      "includeRules": true,
      "includeDocumentation": true,
      "maxContextFiles": 20
    }
  }
}
