{
  "name": "everytriv",
  "version": "1.0.0",
  "description": "EveryTriv - Full Stack Trivia Application",
  "private": true,
  "packageManager": "pnpm@8.15.0",
  "scripts": {
    "api:test": "newman run tools/endpoints-collection.json --reporter-cli-verbose",
    "api:verify-db": "powershell -ExecutionPolicy Bypass -File scripts/verify-db-sync.ps1",
    "api:verify-db-newman": "newman run tools/endpoints-collection.json --folder \"Data Verification\" --reporters cli",
    "build:all": "pnpm run build:server && pnpm run build:client",
    "build:client": "cd client && pnpm run build",
    "build:server": "cd server && pnpm run build",
    "clean:all": "pnpm run clean:server && pnpm run clean:client && pnpm run clean:cache",
    "clean:cache": "rimraf node_modules/.cache node_modules/.vite .vite",
    "clean:client": "cd client && pnpm run clean",
    "clean:server": "cd server && pnpm run clean",
    "dev:check": "node scripts/development/check-local-services.cjs",
    "redis:apply:windows-local": "powershell -ExecutionPolicy Bypass -File scripts/development/apply-redis-windows-local.ps1",
    "redis:install:windows": "winget install --id Redis.Redis --accept-package-agreements --accept-source-agreements",
    "delete-cli-users": "cd server && node ../scripts/delete-cli-users.cjs",
    "docker:dev:up": "docker compose --profile dev up -d",
    "docker:logs": "docker compose logs -f",
    "docker:start": "docker compose up --build -d",
    "docker:status": "docker compose ps",
    "docker:stop": "docker compose down",
    "docs:all": "pnpm run docs:check && pnpm run docs:consistency && pnpm run docs:diagrams",
    "docs:check": "node scripts/documentation/validate-doc-links.cjs",
    "docs:consistency": "node scripts/documentation/validate-doc-consistency.cjs",
    "docs:diagrams": "node scripts/documentation/validate-doc-diagrams.cjs",
    "empty-dirs": "powershell -ExecutionPolicy Bypass -File scripts/empty-dirs.ps1",
    "format": "prettier --config tools/.prettierrc --ignore-path tools/.prettierignore --write \"client/src/**/*.{ts,tsx,js,jsx}\" \"server/src/**/*.{ts,tsx,js,jsx}\" \"shared/**/*.{ts,tsx,js,jsx}\"",
    "format:check": "prettier --config tools/.prettierrc --ignore-path tools/.prettierignore --check \"client/src/**/*.{ts,tsx,js,jsx}\" \"server/src/**/*.{ts,tsx,js,jsx}\" \"shared/**/*.{ts,tsx,js,jsx}\"",
    "imports:check": "npx tsc-alias -p server/tsconfig.json -v && npx tsc-alias -p shared/tsconfig.json -v",
    "imports:fix": "npx tsc-alias -p server/tsconfig.json -v && npx tsc-alias -p shared/tsconfig.json -v",
    "install:all": "pnpm run install:server && pnpm run install:client",
    "install:client": "cd client && pnpm install",
    "install:server": "cd server && pnpm install",
    "knip": "knip -c tools/knip.json",
    "lint": "eslint . --config tools/eslint.config.js",
    "lint:css": "stylelint \"client/src/**/*.css\" --config tools/stylelint.config.cjs",
    "lint:css:fix": "stylelint \"client/src/**/*.css\" --config tools/stylelint.config.cjs --fix",
    "lint:fix": "eslint . --fix --config tools/eslint.config.js",
    "lint:imports": "pnpm run lint:imports:server && pnpm run lint:imports:client && pnpm run lint:imports:shared",
    "lint:imports:client": "npx eslint \"client/src/**/*.{ts,tsx}\" --config tools/eslint.config.js --fix",
    "lint:imports:server": "npx eslint \"server/src/**/*.{ts,tsx}\" --config tools/eslint.config.js --fix",
    "lint:imports:shared": "npx eslint \"shared/**/*.{ts,tsx}\" --config tools/eslint.config.js --fix",
    "repomix": "npx repomix --style plain -o repomix-output.txt",
    "start:client": "cd client && pnpm run start",
    "start:demo": "powershell -ExecutionPolicy Bypass -File scripts/deployment/start-docker-demo-and-sync.ps1",
    "start:demo:local": "powershell -ExecutionPolicy Bypass -File scripts/deployment/start-docker-demo-and-sync.ps1 -NoGitPush",
    "start:demo:up": "docker compose --profile demo-tunnel up --build -d",
    "start:dev": "concurrently -n server,client \"pnpm run start:dev:server\" \"pnpm run start:client\"",
    "start:dev:server": "cd server && pnpm run start:dev",
    "start:dev:windows": "scripts\\development\\start-dev-with-info.bat",
    "start:prod": "scripts\\docker\\start-docker-with-info.bat",
    "start:prod:local": "cd server && pnpm run start",
    "start:server": "cd server && pnpm run start",
    "tunnel:cloudflared": "cloudflared tunnel --no-autoupdate --url http://127.0.0.1:3000",
    "tunnel:cloudflared:logs": "docker compose logs -f cloudflared",
    "webdb:install": "npm install -g @webdb/cli",
    "webdb:start": "webdb --port 22071 --host 127.0.0.1",
    "webdb:start:public": "webdb --port 22071"
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@ianvs/prettier-plugin-sort-imports": "^4.1.1",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.3",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "knip": "^5.63.0",
    "newman": "^6.2.1",
    "prettier": "^3.6.2",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0",
    "tsc-alias": "^1.8.16"
  }
}
