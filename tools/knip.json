{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "workspaces": {
    ".": {
      "entry": [],
      "project": []
    },
    "client": {
      "entry": ["src/main.tsx"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "server": {
      "entry": ["src/main.ts"],
      "project": ["src/**/*.ts"]
    }
  },
  "ignore": [
    "**/*.d.ts",
    "**/node_modules/**",
    "server/src/migrations/**",
    "server/src/config/dataSource.ts",
    "**/index.ts",
    "client/src/components/ui/index.ts",
    "client/src/components/index.ts",
    "client/src/hooks/index.ts",
    "client/src/redux/slices/index.ts",
    "client/src/types/user/index.ts",
    "client/src/views/leaderboard/index.ts",
    "client/src/components/statistics/performance/PerformanceTabContent.tsx",
    "client/src/components/statistics/history/HistoryTabContent.tsx",
    "client/src/components/statistics/leaderboard/LeaderboardTabContent.tsx",
    "client/src/components/admin/performance/PerformanceTabContent.tsx",
    "client/src/components/admin/trivia/TriviaManagementTable.tsx",
    "client/src/components/admin/users/UsersTable.tsx",
    "client/src/components/admin/business/BusinessTabContent.tsx",
    "client/src/components/admin/system/SystemTabContent.tsx",
    "client/src/components/admin/aiProviders/ProviderManagementSection.tsx",
    "server/src/features/**/index.ts",
    "server/src/internal/modules/**/index.ts",
    "server/src/internal/modules/cache/dtos/**/*.ts",
    "tools/eslint.config.js",
    "tools/.prettierrc",
    "OLD/**/*"
  ],
  "ignoreDependencies": ["@types/*", "eslint*", "prettier*"],
  "ignoreBinaries": [
    "powershell",
    "repomix",
    "rimraf",
    "webdb",
    "docker",
    "scriptsdevelopmentstart-dev-with-info.bat",
    "scriptsdockerstart-docker-with-info.bat"
  ],
  "rules": {
    "exports": "warn",
    "files": "warn",
    "dependencies": "warn",
    "devDependencies": "warn",
    "unlisted": "warn",
    "binaries": "warn",
    "types": "off",
    "enumMembers": "off"
  }
}
